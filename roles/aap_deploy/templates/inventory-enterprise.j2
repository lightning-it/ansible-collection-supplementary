# Generated by lit.supplementary.aap_deploy

[automationgateway]
{% for host in aap_deploy_enterprise_gateway_hosts %}
{{ host }} ansible_host={{ host }}
{% endfor %}

[automationcontroller]
{% for host in aap_deploy_enterprise_controller_hosts %}
{{ host }} ansible_host={{ host }}
{% endfor %}

[automationhub]
{% for host in aap_deploy_enterprise_hub_hosts %}
{{ host }} ansible_host={{ host }}
{% endfor %}

[automationeda]
{% for host in aap_deploy_enterprise_eda_hosts %}
{{ host }} ansible_host={{ host }}
{% endfor %}

[database]
{% for host in aap_deploy_enterprise_postgresql_hosts %}
{{ host }} ansible_host={{ host }}
{% endfor %}

{% if aap_deploy_redis_mode == 'cluster' %}
[redis]
{% for host in aap_deploy_redis_hosts %}
{{ host }} ansible_host={{ host }}
{% endfor %}

{% endif %}
[all:vars]
gateway_admin_password='{{ aap_deploy_gateway_admin_password_effective }}'
controller_admin_password='{{ aap_deploy_controller_admin_password_effective }}'
hub_admin_password='{{ aap_deploy_hub_admin_password_effective }}'
eda_admin_password='{{ aap_deploy_eda_admin_password_effective }}'
postgresql_admin_password='{{ aap_deploy_postgresql_admin_password_effective }}'
postgresql_admin_username='{{ aap_deploy_postgresql_admin_username }}'

gateway_pg_host='{{ aap_deploy_gateway_pg_host_effective }}'
gateway_pg_password='{{ aap_deploy_gateway_pg_password_effective }}'
controller_pg_host='{{ aap_deploy_controller_pg_host_effective }}'
controller_pg_password='{{ aap_deploy_controller_pg_password_effective }}'
hub_pg_host='{{ aap_deploy_hub_pg_host_effective }}'
hub_pg_password='{{ aap_deploy_hub_pg_password_effective }}'
eda_pg_host='{{ aap_deploy_eda_pg_host_effective }}'
eda_pg_password='{{ aap_deploy_eda_pg_password_effective }}'

pg_admin_password='{{ aap_deploy_postgresql_admin_password_effective }}'
redis_mode='{{ aap_deploy_redis_mode }}'
bundle_install=true
bundle_dir='{{ aap_deploy_bundle_dir }}'
