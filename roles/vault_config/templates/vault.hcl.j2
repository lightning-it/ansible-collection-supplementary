inputs = {
  vault_url = "{{ vault_config_url }}"

{{ macros.render_block(
  "auth_backends",
  vault_config_auth_backends,
  "key",
  ["type", "path"],
  ["namespace", "description"],
  {}
) }}

{{ macros.render_block(
  "secret_stores",
  vault_config_secret_stores,
  "key",
  ["path"],
  ["namespace", "description", "type", "options"],
  {
    "type": "kv",
    "options": { }
  }
) }}

{{ macros.render_block(
  "policies",
  vault_config_policies,
  "key",
  ["name", "policy"],
  ["namespace"],
  {},
  heredoc_fields=["policy"]
) }}

{{ macros.render_block(
  "approle_secrets",
  vault_config_approle_secrets,
  "key",
  ["role_name", "token_policy"],
  ["namespace", "backend", "kv_mount", "credential_path", "token_type", "token_ttl", "token_max_ttl", "token_period"],
  {
    "kv_mount": vault_config_engine_mount_point,
    "credential_path": inventory_hostname ~ "/vault/approle"
  },
) }}

{{ macros.render_block(
  "vault_pki_roots",
  vault_config_pki_roots,
  "key",
  ["mount", "common_name", "vault_server"],
  ["ttl", "key_type", "key_bits", "country", "locality", "province", "ou", "organization", "policy_name", "namespace"],
  {},
) }}

{{ macros.render_block(
  "vault_pki_intermediates",
  vault_config_pki_intermediates,
  "key",
  ["mount", "common_name", "vault_server"],
  ["ttl", "max_ttl", "key_type", "key_bits", "country", "locality", "province", "ou", "organization", "csr_auto_rebuild", "csr_expiry", "signer_root_id", "sign_method", "external_cert_secret", "external_cert_ready", "store_csr", "namespace"],
  {},
) }}

{{ macros.render_block(
  "vault_pki_roles",
  vault_config_pki_roles,
  "key",
  ["name", "mount"],
  ["key_type", "key_bits", "allowed_domains", "allow_subdomains", "allow_ip_sans", "allow_bare_domains", "allow_glob_domains", "allow_localhost", "generate_lease", "ttl", "max_ttl", "namespace"],
  {},
) }}

{{ macros.render_block(
  "jwt_auth_backends",
  vault_config_jwt_auth_backends,
  "key",
  ["path"],
  ["namespace", "type", "oidc_discovery_url", "bound_issuer", "jwt_validation_pubkeys", "oidc_discovery_ca_pem"],
  {},
  heredoc_fields=["oidc_discovery_ca_pem"]
) }}

{{ macros.render_block(
  "jwt_auth_backend_roles",
  vault_config_jwt_auth_backend_roles,
  "key",
  ["role_name", "backend_key", "user_claim"],
  ["namespace", "role_type", "bound_claims", "bound_claims_type", "bound_audiences", "token_policy"],
  {},
) }}

{{ macros.render_block(
  "transit_secret_backend_key",
  vault_config_transit_secret_backend_keys,
  "key",
  ["name", "backend"],
  ["type", "namespace"],
  {},
) }}

{{ macros.render_block(
  "namespace",
  vault_config_namespaces,
  "path",
  ["path"],
  [],
  {},
) }}
}
