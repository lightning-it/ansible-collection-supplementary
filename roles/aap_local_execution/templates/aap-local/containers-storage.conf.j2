[storage]
driver = "overlay"
graphroot = "{{ aap_local_execution_podman_root_graphroot_effective }}"
runroot = "{{ aap_local_execution_podman_root_runroot_effective }}"

[storage.options]
{% if aap_local_execution_podman_fuse_overlayfs.stat.exists | default(false) %}
mount_program = "/usr/bin/fuse-overlayfs"
{% endif %}
