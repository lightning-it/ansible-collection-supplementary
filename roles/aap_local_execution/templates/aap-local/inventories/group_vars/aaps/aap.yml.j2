---
aap_secret_backend: {{ aap_local_execution_effective_secret_backend | to_json }}
aap_preflight_expected_ansible_user: {{ aap_local_execution_effective_setup_user | to_json }}

aap_deploy_setup_download_version: "2.7"

aap_deploy_install_dir: /appl/aap
aap_deploy_setup_dir: "{{ '{{' }} aap_deploy_install_dir {{ '}}' }}/setup"
aap_deploy_tls_dir: "{{ '{{' }} aap_deploy_install_dir {{ '}}' }}/tls"
aap_deploy_installed_marker_path: "{{ '{{' }} aap_deploy_install_dir {{ '}}' }}/.aap_containerized_installed"
aap_deploy_gateway_main_url: "https://{{ aap_fqdn }}:8446"
aap_deploy_gateway_verify_url: "{{ '{{' }} aap_deploy_gateway_main_url {{ '}}' }}"
aap_deploy_hub_upload_readiness_url: "https://{{ aap_fqdn }}:8444/api/galaxy/pulp/api/v3/status/"
aap_deploy_hub_container_registry_url: "https://{{ aap_fqdn }}:8444"
aap_deploy_hub_seed_execution_environment_images: {{ aap_hub_seed_execution_environment_images | default(true) | bool | lower }}
aap_deploy_eda_api_url: "https://{{ aap_fqdn }}:8445"

aap_deploy_install_user: {{ aap_local_execution_effective_install_user }}
aap_deploy_install_user_home: /appl/home/{{ aap_local_execution_effective_install_user }}
aap_deploy_install_user_shell: /bin/bash
aap_deploy_reset_partial_install_enabled: true

aap_deploy_growth_gateway_host: {{ aap_inventory_host | to_json }}
aap_deploy_growth_controller_host: {{ aap_inventory_host | to_json }}
aap_deploy_growth_hub_host: {{ aap_inventory_host | to_json }}
aap_deploy_growth_eda_host: {{ aap_inventory_host | to_json }}
aap_deploy_growth_automationmetrics_host: {{ aap_inventory_host | to_json }}
aap_deploy_growth_postgresql_host: {{ aap_inventory_host | to_json }}
aap_deploy_host_alias_address: "{{ '{{' }} ansible_default_ipv4.address {{ '}}' }}"
aap_deploy_gateway_pg_host: {{ (aap_ansible_host | default(aap_fqdn, true)) | to_json }}
aap_deploy_controller_pg_host: {{ (aap_ansible_host | default(aap_fqdn, true)) | to_json }}
aap_deploy_hub_pg_host: {{ (aap_ansible_host | default(aap_fqdn, true)) | to_json }}
aap_deploy_eda_pg_host: {{ (aap_ansible_host | default(aap_fqdn, true)) | to_json }}
aap_deploy_automationmetrics_pg_host: {{ (aap_ansible_host | default(aap_fqdn, true)) | to_json }}
aap_deploy_automationmetrics_controller_read_pg_host: {{ (aap_ansible_host | default(aap_fqdn, true)) | to_json }}

aap_runbook_manage_rhsm: false
aap_runbook_manage_repos: false
aap_runbook_os_prep_enabled: false
aap_runbook_manage_host_packages: false
aap_runbook_manage_install_user: false
aap_runbook_manage_podman: false
aap_runbook_allow_ansible_user_sudo_to_install_user: true

aap_preflight_check_prepared_host: {{ aap_preflight_check_prepared_host | default(false) | bool | lower }}
aap_preflight_minimum_distribution_version: {{ aap_preflight_minimum_distribution_version | default('9.6', true) | to_json }}
aap_preflight_expected_fqdn: {{ aap_fqdn | to_json }}
aap_preflight_minimum_vcpus: {{ aap_preflight_minimum_vcpus | default(4) }}
aap_preflight_minimum_memory_mb: {{ aap_preflight_minimum_memory_mb | default(16000) }}
aap_preflight_appl_minimum_free_mb: {{ aap_preflight_appl_minimum_free_mb | default(50000) }}
aap_preflight_check_execution_environment: {{ aap_configure_registry_ee | default(false) | bool | lower }}
aap_preflight_ee_registry: {{ aap_registry_fqdn | default('', true) | to_json }}
aap_preflight_ee_approved_registry: {{ aap_registry_fqdn | default('', true) | to_json }}
aap_preflight_ee_repository: {{ aap_ee_repository | default('', true) | to_json }}
aap_preflight_ee_approved_repository: {{ aap_ee_repository | default('', true) | to_json }}
aap_preflight_ee_digest: {{ aap_ee_digest | default('', true) | to_json }}
aap_preflight_ee_validate_certs: {{ aap_registry_validate_certs | default(true) | bool | lower }}
aap_preflight_ee_auth_file: {{ aap_registry_auth_file | default('', true) | to_json }}

ansible_remote_tmp: /appl/ansible-tmp
ansible_remote_tmp_bootstrap_raw: {{ aap_remote_tmp_bootstrap_raw | default(true) | bool | lower }}
aap_deploy_manage_install_tmp_dir: true
aap_deploy_install_tmp_dir: /appl/tmp
aap_deploy_install_environment:
  TMPDIR: /appl/tmp
  TEMP: /appl/tmp
  TMP: /appl/tmp

aap_cac_gateway_hostname: "https://{{ aap_fqdn }}"

aap_ops_health_url: "https://{{ aap_fqdn }}/"
aap_ops_validate_certs: true
aap_ops_manage_systemd: false

aap_prepare_bundle_required: true
aap_prepare_no_log: false
aap_prepare_bundle_source: remote
aap_prepare_bundle_remote_src: "{{ '{{' }} lookup('ansible.builtin.env', 'AAP_BUNDLE_REMOTE_SRC') {{ '}}' }}"
aap_prepare_bundle_dest: "{{ '{{' }} aap_deploy_install_dir {{ '}}' }}/aap-containerized-setup.tar.gz"
aap_prepare_manifest_required: true
aap_prepare_manifest_source: remote
aap_prepare_manifest_remote_src: "{{ '{{' }} lookup('ansible.builtin.env', 'AAP_MANIFEST_REMOTE_SRC') {{ '}}' }}"
aap_prepare_manifest_dest: "{{ '{{' }} aap_deploy_install_dir {{ '}}' }}/manifest.zip"
aap_prepare_artifact_dir: "{{ '{{' }} lookup('ansible.builtin.env', 'AAP_ARTIFACT_DIR') {{ '}}' }}"

aap_deploy_tls_enabled: true
aap_deploy_tls_source: customer_files
aap_tls_selfsigned_output_dir: /runner/project/files/tls
aap_tls_selfsigned_common_name: {{ aap_fqdn | to_json }}
aap_tls_selfsigned_dns_names:
  - {{ aap_fqdn | to_json }}
  - {{ aap_inventory_host | to_json }}
aap_deploy_tls_customer_files:
  ca_cert_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap-selfsigned-ca.crt"
  gateway:
    cert_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.crt"
    key_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.key"
  controller:
    cert_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.crt"
    key_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.key"
  hub:
    cert_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.crt"
    key_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.key"
  eda:
    cert_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.crt"
    key_src: "{{ '{{' }} aap_tls_selfsigned_output_dir {{ '}}' }}/aap.key"

aap_cac_controller_license_required: true

aap_orgs:
  - name: org-modulix
aap_org_primary: "{{ '{{' }} (aap_orgs | first).name {{ '}}' }}"
aap_cac_controller_organizations:
  - name: org-modulix

controller_settings:
  - name: TOWER_URL_BASE
    value: "https://{{ aap_fqdn }}"

# The private-registry credential and EE are configured by the canonical CaC
# roles after AAP is reachable.  The image is intentionally digest-pinned.
{% if aap_local_execution_configure_registry_ee_effective | bool %}
controller_credentials:
  - name: {{ aap_registry_credential_name | default('MHB Container Registry', true) | to_json }}
    organization: {{ aap_org_primary | default('org-modulix', true) | to_json }}
    credential_type: Container Registry
    inputs:
      host: "https://{{ aap_registry_fqdn }}"
      username: "{{ '{{' }} aap_registry_username_input {{ '}}' }}"
      password: "{{ '{{' }} aap_registry_password_input {{ '}}' }}"
      verify_ssl: true

controller_execution_environments:
  - name: {{ aap_execution_environment_name | default('ModuLix Certified EE', true) | to_json }}
    image: "{{ aap_ee_repository }}@{{ aap_ee_digest }}"
    credential: {{ aap_registry_credential_name | default('MHB Container Registry', true) | to_json }}
    pull: always
{% endif %}
