{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitType(chore)",
    ":semanticCommitScope(deps)"
  ],
  "renovate-config": {
    "enabled": false
  },
  "labels": ["dependencies", "renovate"],
  "baseBranchPatterns": ["develop"],
  "ignorePaths": ["collections/requirements-rh.yml"],
  "timezone": "UTC",
  "schedule": [],
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Automerge safe non-major updates into develop after CI passes",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest",
        "pinDigest",
        "lockFileMaintenance"
      ],
      "addLabels": ["safe-automerge"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": ["major"],
      "addLabels": ["breaking-update"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Keep every component of the GitHub Actions toolchain on one version",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Keep community.general on 11.x for linux_system_roles compatibility",
      "matchDepNames": ["community.general"],
      "matchDatasources": ["galaxy-collection"],
      "allowedVersions": "/^11\\./"
    },
    {
      "description": "Pin community.vmware to 5.10.0 for ansible-core 2.18.18 compatibility",
      "matchDepNames": ["community.vmware"],
      "matchDatasources": ["galaxy-collection"],
      "allowedVersions": "/^5\\.10\\.0$/"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Digest-pinned validation images in the managed pre-commit configuration",
      "managerFilePatterns": [
        "/(^|.*/)\\.pre-commit-config\\.ya?ml$/"
      ],
      "matchStrings": [
        "docker\\.io/(?<depName>rhysd/actionlint|renovate/renovate):(?<currentValue>[0-9.]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "{{{depName}}}",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Digest-pinned devtool execution image in the managed wrapper",
      "managerFilePatterns": [
        "/(^|.*/)scripts/wunder-devtools-ee\\.sh$/"
      ],
      "matchStrings": [
        "(?<depName>quay\\.io/l-it/ee-wunder-devtools-ubi9):v(?<currentValue>[0-9.]+)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "{{{depName}}}",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Digest-pinned shipped role, test, and source-inventory images",
      "managerFilePatterns": [
        "/(^|.*/)containerfiles/.*/Containerfile$/",
        "/(^|.*/)manifests/.*\\.ya?ml$/",
        "/(^|.*/)roles/.*/defaults/main\\.ya?ml$/",
        "/(^|.*/)meta/source-dependencies\\.ya?ml$/",
        "/(^|.*/)molecule/keycloak-(?:tiny|heavy)/(?:converge|verify)\\.ya?ml$/"
      ],
      "matchStrings": [
        "(?<depName>(?:[a-z0-9][a-z0-9.-]*\\.[a-z]{2,})(?::[0-9]+)?/[A-Za-z0-9._/-]+):(?<currentValue>[A-Za-z0-9][A-Za-z0-9._-]*)@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "{{{depName}}}",
      "versioningTemplate": "docker"
    }
  ]
}
