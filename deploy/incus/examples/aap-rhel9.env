INCUS_RHEL98_IMAGE=local:rhel98-ci
INCUS_RHEL9_IMAGE=local:rhel9-ci
INCUS_SSH_USER=cloud-user
INCUS_FQDN_SUFFIX=incus.local

# Optional sizing overrides for VM mode.
INCUS_VM_CPU=4
INCUS_VM_MEMORY=16GiB

# Optional full-install inputs for protected/private testing.
# AAP_BUNDLE_FILE=/srv/aap/aap-containerized-setup.tar.gz
# MOLECULE_AAP_FULL_INSTALL=true
